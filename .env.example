# ============================================================
# PAE Inventory System — Variables de Entorno
# ============================================================
# Copiar este archivo como .env y rellenar con las credenciales
# de tu proyecto Supabase (Settings > API).
# ============================================================

# URL del proyecto Supabase (Settings > API > Project URL)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Llave pública anon (Settings > API > Project API keys > anon/public)
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Service Role Key (Settings > API > Project API keys > service_role/secret)
# NO es expuesta al frontend. Usada por db-seed.js y Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
